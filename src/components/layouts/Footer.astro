---
import { Github, Linkedin } from "lucide-astro";

const currentYear = new Date().getFullYear();

const links = [
  { label: "Início", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Sobre", href: "/sobre" },
  { label: "Contato", href: "/contato" },
];

const utilityLinks = [
  { label: "Termos de Uso", href: "/termos" },
  { label: "Privacidade", href: "/privacidade" },
];

const social = [
  {
    name: "GitHub",
    href: "https://github.com/joseph2reis",
    icon: Github,
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/joseph2reis/",
    icon: Linkedin,
  },
];
---

<footer class="mt-20 border-t border-border bg-surface/30">
  <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 gap-10 text-center md:grid-cols-2 md:text-left xl:grid-cols-4 xl:gap-8">
      <div class="flex flex-col items-center space-y-6 md:items-start">
        <a
          href="/"
          class="inline-flex items-center gap-3 text-text leading-none"
          style="font-family: 'Pacifico', cursive;"
          aria-label="Café Com Fé"
        >
          <span class="text-3xl">
            Café <span class="text-primary">com Fé</span>
          </span>
        </a>

        <div class="flex justify-center gap-x-6 md:justify-start">
          {
            social.map((item) => {
              const Icon = item.icon;
              return (
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-text-muted hover:text-primary transition-colors"
                >
                  <span class="sr-only">{item.name}</span>
                  <Icon size={25} stroke-width={1.5} />
                </a>
              );
            })
          }
        </div>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-text">
          Navegação
        </h3>
        <ul class="mt-4 space-y-4">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-muted hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-text">
          Links Úteis
        </h3>
        <ul class="mt-4 space-y-4">
          {
            utilityLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-muted hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="space-y-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-text">
          Crie o seu site
        </h3>
        <p class="text-sm text-text-muted">
          Conheça o{" "}
          <a
            href="https://jrstudio.pages.dev/"
            class="text-primary hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            JR Studio Digital
          </a>
          , e tenha sua presença digital.
        </p>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border/50 pt-8 md:flex-row"
    >
      <p class="text-xs text-text-muted">
        &copy; {currentYear} Caf&eacute; Com F&eacute;. Todos os direitos reservados.
      </p>
      <p
        class="text-[10px] text-text-muted/50 uppercase tracking-widest font-mono"
      >
        Feito com Amor & Propósito
      </p>
    </div>
  </div>
</footer>
