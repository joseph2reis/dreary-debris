---
// BlogProse.astro
---

<article>
  <div class="blogger-content">
    <slot />
  </div>
</article>

<style is:global>
  @reference "../styles/global.css";

  .blogger-content {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.8;
  }

  .blogger-content p,
  .blogger-content span,
  .blogger-content div {
    color: var(--color-text-muted) !important;
  }

  .blogger-content div:has(> br:only-child) {
    margin: 0.25rem 0;
  }

  .blogger-content p:empty {
    display: none;
  }

  .blogger-content ul {
    list-style: disc outside !important;
    padding-left: 1.5rem !important;
    margin: 1.25rem 0 !important;
  }

  .blogger-content ol {
    list-style: decimal outside !important;
    padding-left: 1.5rem !important;
    margin: 1.25rem 0 !important;
  }

  .blogger-content li {
    display: list-item !important;
    margin: 0.45rem 0;
  }

  .blogger-content li::marker {
    color: var(--color-primary);
  }

  .blogger-content h1,
  .blogger-content h2,
  .blogger-content h3,
  .blogger-content h4,
  .blogger-content h5,
  .blogger-content h6 {
    display: block !important;
    color: var(--color-text) !important;
    line-height: 1.3 !important;
    font-weight: 700 !important;
  }

  .blogger-content h1 {
    font-size: 2.1rem !important;
    margin: 2.2rem 0 0.8rem !important;
  }

  .blogger-content h2 {
    font-size: 1.8rem !important;
    margin: 2rem 0 0.75rem !important;
  }

  .blogger-content h3 {
    font-size: 1.5rem !important;
    margin: 1.8rem 0 0.65rem !important;
  }

  .blogger-content h4 {
    font-size: 1.25rem !important;
    margin: 1.4rem 0 0.55rem !important;
  }

  .blogger-content h5 {
    font-size: 1.1rem !important;
    margin: 1.2rem 0 0.45rem !important;
  }

  .blogger-content h6 {
    font-size: 1rem !important;
    margin: 1.1rem 0 0.4rem !important;
  }

  .blogger-content p {
    @apply my-2;
  }

  /* .blogger-content img {
    @apply rounded-lg border border-[--color-border];
  } */

  .blogger-content .separator {
    clear: both !important;
    margin: 1.5rem 0 !important;
    text-align: center;
  }

  .blogger-content .separator a {
    display: inline-block;
  }

  .blogger-content .separator img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .blogger-content a[style*="float: right"] {
    float: right !important;
    margin: 0 0 1rem 1rem !important;
  }

  .blogger-content .tr-caption-container {
    @apply bg-[--color-surface] border border-[--color-border] rounded-xl p-2 my-6;
  }

  .blogger-content .tr-caption-container .tr-caption {
    @apply text-sm text-[--color-text-muted] mt-2;
  }

  .blogger-content table {
    @apply w-full border-collapse my-6;
  }

  .blogger-content th,
  .blogger-content td {
    @apply border border-[--color-border] px-3 py-2;
  }

  .blogger-content iframe {
    @apply w-full rounded-lg border border-[--color-border];
    aspect-ratio: 16 / 9;
  }

  .blogger-content blockquote {
    @apply border-l-4 border-[--color-primary] pl-5 pr-0 py-0 my-8;
    background: transparent;
    font-style: normal;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text);
    border-left-style: solid !important;
    border-left-width: 4px !important;
    border-left-color: var(--color-primary) !important;
    border-radius: 0 !important;
    margin: 2rem 0 !important;
    padding: 0 0 0 1rem !important;
  }

  .blogger-content blockquote :is(div, p, span) {
    color: inherit !important;
  }

  .blogger-content blockquote blockquote {
    margin: 0.9rem 0 0.4rem !important;
  }

  .blogger-content blockquote.highlight {
    border-left-color: var(--color-primary);
    background: transparent;
    font-weight: 700;
    color: var(--color-text) !important;
    letter-spacing: 0.01em;
  }

  .blogger-content blockquote.soft {
    border-left-color: var(--color-primary) !important;
    background: transparent;
    color: var(--color-text-muted) !important;
    font-weight: 500;
  }

  .blogger-content blockquote.centered {
    border-left-color: var(--color-primary);
    border-left-width: 4px;
    border-left-style: solid;
    border-radius: 0;
    text-align: center;
    background: transparent;
    font-size: 1.2rem;
    font-weight: 700;
    padding: 0 0 0 1rem !important;
  }

  .blogger-content b,
  .blogger-content strong,
  .blogger-content i,
  .blogger-content em,
  .blogger-content u {
    color: var(--color-text);
  }

  .blogger-content :is(span, div, p)[style*="font-size: x-small"] {
    font-size: 0.75rem !important;
  }

  .blogger-content :is(span, div, p)[style*="font-size: small"] {
    font-size: 0.875rem !important;
  }

  .blogger-content :is(span, div, p)[style*="font-size: medium"] {
    font-size: 1.125rem !important;
  }

  .blogger-content :is(span, div, p)[style*="font-size: large"] {
    font-size: 1.25rem !important;
  }

  .blogger-content :is(span, div, p)[style*="font-size: x-large"] {
    font-size: 1.5rem !important;
  }

  @media (max-width: 768px) {
    .blogger-content a[style*="float: right"] {
      float: none !important;
      display: block !important;
      margin: 0 auto 1rem !important;
      text-align: center !important;
    }
  }
</style>
