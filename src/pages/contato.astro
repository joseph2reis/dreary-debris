---
import Layout from "../layouts/Layout.astro";
import { Mail, MessageCircle, Send, UserRound } from "lucide-astro";

const email = "josenildo2reis@gmail.com";
const whatsappNumber = "5591985014864";
const whatsappHref = `https://wa.me/${whatsappNumber}`;
---

<Layout
  title="Contato | Café Com Fé"
  description="Entre em contato com o Café Com Fé por e-mail ou WhatsApp."
>
  <main class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
    <section class="mx-auto mb-14 max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-primary">
        Vamos Conversar
      </p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-text sm:text-5xl">
        Fale comigo
      </h1>
      <p class="mt-4 text-base leading-relaxed text-text-muted">
        Se você quer trocar uma ideia sobre fé, programação, projetos ou parcerias,
        pode me chamar por e-mail, WhatsApp ou usar o formulário abaixo.
      </p>
    </section>

    <section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-3xl border border-border bg-surface p-8 shadow-sm">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-text">Enviar mensagem</h2>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">
            Este formulário abre seu cliente de e-mail com a mensagem pronta para
            envio.
          </p>
        </div>

        <form id="contact-form" class="space-y-5">
          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-text">Nome</span>
              <div class="relative">
                <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">
                  <UserRound size={16} />
                </span>
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full rounded-xl border border-border bg-background py-3 pl-10 pr-4 text-sm text-text outline-none transition focus:border-primary"
                  placeholder="Seu nome"
                />
              </div>
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-text">E-mail</span>
              <div class="relative">
                <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">
                  <Mail size={16} />
                </span>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-border bg-background py-3 pl-10 pr-4 text-sm text-text outline-none transition focus:border-primary"
                  placeholder="voce@email.com"
                />
              </div>
            </label>
          </div>

          <label class="block">
            <span class="mb-2 block text-sm font-medium text-text">Assunto</span>
            <input
              type="text"
              name="subject"
              required
              class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-text outline-none transition focus:border-primary"
              placeholder="Sobre o que você quer falar?"
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-sm font-medium text-text">Mensagem</span>
            <textarea
              name="message"
              rows="7"
              required
              class="w-full rounded-2xl border border-border bg-background px-4 py-3 text-sm text-text outline-none transition focus:border-primary"
              placeholder="Escreva sua mensagem aqui..."
            ></textarea>
          </label>

          <div
            id="contact-feedback"
            class="hidden rounded-xl border border-green-500/20 bg-green-500/10 px-4 py-3 text-sm text-green-700"
          ></div>

          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-bold text-white transition-transform hover:scale-[1.02]"
          >
            <Send size={16} />
            Enviar por e-mail
          </button>
        </form>
      </div>

      <div class="space-y-6">
        <div class="rounded-3xl border border-border bg-surface p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary">
            <Mail size={22} />
          </div>
          <h2 class="mt-5 text-2xl font-bold text-text">E-mail direto</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">
            Se preferir, mande direto para:
          </p>
          <a
            href={`mailto:${email}`}
            class="mt-4 inline-block break-all text-base font-semibold text-primary hover:underline"
          >
            {email}
          </a>
        </div>

        <div class="rounded-3xl border border-border bg-surface p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-500/10 text-green-600">
            <MessageCircle size={22} />
          </div>
          <h2 class="mt-5 text-2xl font-bold text-text">WhatsApp</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">
            Para uma conversa mais rápida, você também pode chamar por WhatsApp.
          </p>
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 rounded-full border border-green-500/20 bg-green-500/10 px-5 py-3 text-sm font-bold text-green-600 transition-colors hover:bg-green-500/15"
          >
            <MessageCircle size={16} />
            {whatsappNumber}
          </a>
        </div>

        <div class="rounded-3xl border border-border bg-surface p-8">
          <h2 class="text-xl font-bold text-text">Resposta</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">
            Eu respondo conforme minha disponibilidade. Para assuntos objetivos,
            inclua contexto suficiente no assunto e na mensagem.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script define:vars={{ email }}>
  const form = document.getElementById("contact-form");
  const feedback = document.getElementById("contact-feedback");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    if (!(form instanceof HTMLFormElement)) return;

    const data = new FormData(form);
    const name = data.get("name")?.toString().trim() ?? "";
    const senderEmail = data.get("email")?.toString().trim() ?? "";
    const subject = data.get("subject")?.toString().trim() ?? "";
    const message = data.get("message")?.toString().trim() ?? "";

    const fullSubject = `[Contato Site] ${subject}`;
    const fullBody = [
      `Nome: ${name}`,
      `E-mail: ${senderEmail}`,
      "",
      "Mensagem:",
      message,
    ].join("\n");

    const mailtoHref = `mailto:${email}?subject=${encodeURIComponent(fullSubject)}&body=${encodeURIComponent(fullBody)}`;

    if (feedback) {
      feedback.textContent =
        "Abrindo seu aplicativo de e-mail com a mensagem preenchida.";
      feedback.classList.remove("hidden");
    }

    window.location.href = mailtoHref;
  });
</script>
